#creating backend of bank account 
#how to work banking system 
class Bank:
  def __init__(self,name,account_number,balance,pin):
    self.name = name
    self.account_number = account_number
    self.balance = balance
    self.history=[]
    self.pin = pin

  def display_details(self):
    print("\n ------accounts details-------")
    print("account holder:",self.name)
    print("account_number:",self.account_number)
    print("balance:",self.balance)


  def credit (self,amount):
    self.balance +=amount
    self.history.append(f"credited Rs.{amount}")
    print(f"Rs.{amount} credited sucessfully.")
    print("updated balance:",self.balance)

  def debit(self,amount,pin):
    if pin !=self.pin:
      print( "Incorrect pin!!")
      return
    if amount<=self.balance:
      self.balance -= amount
      self.history.append(f"debited Rs.{amount}")
      print(f"Rs.{amount} debited sucessfully")
      print("updated balance:",self.balance)
    else:
      print("unsufficient balance!!!")



  def check_balance(self):
    print("current balance:",self.balance)

  def transaction_history(self):
    print("\n Transaction History")
    for  transaction in self.history:
      print(transaction)

